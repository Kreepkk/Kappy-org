{
    "compilerOptions": {
        "target": "es2022",
        "lib": ["ES2023"],
        "module": "node16",

        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "moduleResolution": "node16",

        "outDir": "dist"
    },
    "exclude": ["node_modules"],
    "include": ["src/**/*.ts"]
}